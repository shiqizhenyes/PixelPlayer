    <string name="beta_sheet_before_1">Søk i eksisterende åpne og lukkede issues for å unngå duplikater.</string>
    <string name="beta_sheet_before_2">Oppdater til siste PixelPlayer-versjon og bekreft at problemet fortsatt oppstår.</string>
