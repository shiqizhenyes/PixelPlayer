    <!-- BetaInfoBottomSheet -->
    <string name="beta_sheet_version">Beta 0.7.0</string>
    <string name="beta_sheet_letter">β</string>
    <string name="beta_sheet_welcome_title">Bienvenido a PixelPlayer 0.7.0-beta</string>
    <string name="beta_sheet_welcome_body">Estás usando una versión beta que puede contener errores, fallos o funciones experimentales. Ayúdanos a mejorar informando de los problemas.</string>
    <string name="beta_sheet_expect_title">Qué esperar</string>
    <string name="beta_sheet_expect_1">Pueden ocurrir errores, fallos o funciones incompletas de forma inesperada.</string>
    <string name="beta_sheet_expect_2">Algunas funciones pueden cambiar o eliminarse sin previo aviso.</string>
    <string name="beta_sheet_expect_3">Las versiones beta pueden ser más inestables que las versiones de lanzamiento.</string>
    <string name="beta_sheet_expect_4">Comprueba siempre si hay actualizaciones antes de informar de un problema conocido.</string>
    <string name="beta_sheet_expect_summary">Qué pueden cambiar, romper o mejorar las versiones beta durante las pruebas.</string>
    <string name="beta_sheet_github_title">Acceso rápido a problemas de GitHub</string>
    <string name="beta_sheet_github_body">Busca primero, luego abre un informe enfocado para errores, fallos, solicitudes o preguntas.</string>
    <string name="beta_sheet_open_issues">Ver problemas abiertos</string>
    <string name="beta_sheet_report_bug">Informar de un error o fallo</string>
    <string name="beta_sheet_report_body">Comparte los pasos para reproducir, los resultados esperados, los resultados reales y los detalles de tu dispositivo y sistema operativo.</string>
    <string name="beta_sheet_report_title">Cómo informar</string>
    <string name="beta_sheet_report_summary">Una lista de comprobación rápida antes de abrir un nuevo problema.</string>
    <string name="beta_sheet_before_title">Antes de abrir un problema</string>
    <string name="beta_sheet_before_1">Busca en los problemas abiertos y cerrados existentes para evitar duplicados.</string>
    <string name="beta_sheet_before_2">Actualiza a la última versión de PixelPlayer y confirma que el problema sigue ocurriendo.</string>
    <string name="beta_sheet_before_3">Reinicia la aplicación y confirma que el problema persiste.</string>
    <string name="beta_sheet_before_4">Intenta reproducirlo y escribe los pasos exactos.</string>
    <string name="beta_sheet_issue_type_title">¿Qué tipo de problema?</string>
    <string name="beta_sheet_issue_type_bug">Informe de error: Algo se comporta incorrectamente.</string>
    <string name="beta_sheet_issue_type_feature">Solicitud de función: Añadir una nueva función o mejora.</string>
    <string name="beta_sheet_issue_type_question">Pregunta: Usa Discusiones si está habilitado, o abre un problema con la etiqueta de pregunta.</string>
    <string name="beta_sheet_bug_title">Informe de error</string>
    <string name="beta_sheet_bug_summary_text">Copia estos campos cuando algo se comporte incorrectamente o falle.</string>
    <string name="beta_sheet_bug_template_title">Informe de error</string>
    <string name="beta_sheet_bug_summary">Resumen breve:</string>
    <string name="beta_sheet_bug_expected">Comportamiento esperado:</string>
    <string name="beta_sheet_bug_actual">Comportamiento actual:</string>
    <string name="beta_sheet_bug_steps">Pasos para reproducir: 1. 2. 3.</string>
    <string name="beta_sheet_bug_frequency">¿Con qué frecuencia ocurre? Siempre / A veces / Raras veces.</string>
    <string name="beta_sheet_bug_screenshot">Captura de pantalla / vídeo: si está disponible.</string>
    <string name="beta_sheet_bug_logs">Registros / pila de llamadas: si está disponible.</string>
    <string name="beta_sheet_env_title">Entorno</string>
    <string name="beta_sheet_env_version">Versión de PixelPlayer:</string>
