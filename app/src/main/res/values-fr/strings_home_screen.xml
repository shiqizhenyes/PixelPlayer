    <!-- BetaInfoBottomSheet -->
    <string name="beta_sheet_version">Bêta 0.7.5</string>
    <string name="beta_sheet_letter">β</string>
    <string name="beta_sheet_welcome_title">Bienvenue dans PixelPlayer 0.7.5-bêta</string>
    <string name="beta_sheet_welcome_body">Vous utilisez une version bêta qui peut contenir des bugs, des plantages ou des fonctionnalités expérimentales. Aidez-nous à nous améliorer en signalant les problèmes.</string>
    <string name="beta_sheet_expect_title">À quoi s\'attendre</string>
    <string name="beta_sheet_expect_1">Des bugs, des plantages ou des fonctionnalités incomplètes peuvent survenir de manière inattendue.</string>
    <string name="beta_sheet_expect_2">Certaines fonctionnalités peuvent changer ou être supprimées sans préavis.</string>
    <string name="beta_sheet_expect_3">Les versions bêta peuvent être plus instables que les versions de release.</string>
    <string name="beta_sheet_expect_4">Vérifiez toujours les mises à jour avant de signaler un problème connu.</string>
    <string name="beta_sheet_expect_summary">Ce que les versions bêta peuvent changer, casser ou améliorer pendant les tests.</string>
    <string name="beta_sheet_github_title">Raccourci vers les tickets GitHub</string>
    <string name="beta_sheet_github_body">Recherchez d\'abord, puis ouvrez un rapport précis pour les bugs, plantages, demandes ou questions.</string>
    <string name="beta_sheet_open_issues">Ouvrir les tickets existants</string>
    <string name="beta_sheet_report_bug">Signaler un ticket ou un crash</string>
    <string name="beta_sheet_report_body">Partagez les étapes de reproduction, le résultat attendu, le résultat actuel et les détails de votre appareil/OS.</string>
    <string name="beta_sheet_report_title">Comment signaler</string>
    <string name="beta_sheet_report_summary">Une liste de contrôle rapide avant d\'ouvrir un nouveau ticket.</string>
    <string name="beta_sheet_before_title">Avant d\'ouvrir un ticket</string>
    <string name="beta_sheet_before_1">Recherchez parmi les tickets existants ouverts et fermés pour éviter les doublons.</string>
    <string name="beta_sheet_before_2">Mettez à jour vers la dernière version de PixelPlayer et confirmez que le problème persiste.</string>
    <string name="beta_sheet_before_3">Redémarrez l\'application et confirmez que le problème persiste.</string>
    <string name="beta_sheet_before_4">Essayez de le reproduire et notez les étapes exactes.</string>
    <string name="beta_sheet_issue_type_title">Quel type de ticket ?</string>
    <string name="beta_sheet_issue_type_bug">Rapport de bug : Quelque chose se comporte de manière incorrecte.</string>
    <string name="beta_sheet_issue_type_feature">Demande de fonctionnalité : Ajouter une nouvelle fonctionnalité ou amélioration.</string>
    <string name="beta_sheet_issue_type_question">Question : Utilisez Discussions si activé, ou ouvrez un ticket avec le label question.</string>
    <string name="beta_sheet_bug_title">Rapport de bug</string>
    <string name="beta_sheet_bug_summary_text">Copiez ces champs lorsque quelque chose se comporte de manière incorrecte ou plante.</string>
    <string name="beta_sheet_bug_template_title">Rapport de bug</string>
    <string name="beta_sheet_bug_summary">Court résumé :</string>
    <string name="beta_sheet_bug_expected">Comportement attendu :</string>
    <string name="beta_sheet_bug_actual">Comportement actuel :</string>
    <string name="beta_sheet_bug_steps">Étapes pour reproduire : 1. 2. 3.</string>
    <string name="beta_sheet_bug_frequency">À quelle fréquence cela se produit-il ? Toujours / Parfois / Rarement.</string>
    <string name="beta_sheet_bug_screenshot">Capture d\'écran / vidéo : si disponible.</string>
    <string name="beta_sheet_bug_logs">Journaux / trace de la pile : si disponible.</string>
    <string name="beta_sheet_env_title">Environnement</string>
    <string name="beta_sheet_env_version">Version de PixelPlayer :</string>
    <string name="beta_sheet_env_source">Source d\'installation : GitHub Release, build de débogage, build nightly, etc.</string>
    <string name="beta_sheet_env_android">Version d\'Android :</string>
    <string name="beta_sheet_env_device">Modèle d\'appareil :</string>
    <string name="beta_sheet_env_extra">Contexte supplémentaire : utilisation de carte SD, paramètres spéciaux, autorisations, etc.</string>
    <string name="beta_sheet_feature_title">Demande de fonctionnalité</string>
    <string name="beta_sheet_feature_summary">Copiez ces champs lorsque vous souhaitez une nouvelle fonctionnalité ou amélioration.</string>
    <string name="beta_sheet_feature_problem">Description du problème : Quel problème essayez-vous de résoudre ?</string>
    <string name="beta_sheet_feature_solution">Solution proposée : Comment cela devrait-il fonctionner ?</string>
    <string name="beta_sheet_feature_alternatives">Alternatives envisagées : D\'autres approches ?</string>
    <string name="beta_sheet_feature_scope">Portée : Quels écrans ou flux sont concernés ?</string>
    <string name="beta_sheet_feature_mockup">Maquette ou image de référence si disponible.</string>
    <string name="beta_sheet_quality_title">Titres, confidentialité et portée</string>
    <string name="beta_sheet_quality_summary">Rendre le rapport facile à trier et sûr à partager.</string>
    <string name="beta_sheet_title_examples_title">Bons titres de tickets</string>
    <string name="beta_sheet_title_example_1">Égaliseur : L\'indicateur se déplace lors du changement d\'onglets de préréglage</string>
    <string name="beta_sheet_title_example_2">Recherche : L\'historique n\'apparaît pas pour une requête vide</string>
    <string name="beta_sheet_title_example_3">Fonctionnalité : Ajouter l\'option de tri de playlist « Récemment ajouté »</string>
    <string name="beta_sheet_avoid_title">Veuillez éviter</string>
    <string name="beta_sheet_avoid_1">Les rapports génériques comme « Ça ne marche pas ».</string>
    <string name="beta_sheet_avoid_2">Plusieurs problèmes non liés dans un seul ticket.</string>
    <string name="beta_sheet_avoid_3">Des journaux ou des captures d\'écran non anonymisés contenant des données privées.</string>
    <string name="beta_sheet_privacy_title">Note sur la confidentialité</string>
    <string name="beta_sheet_privacy_body">Avant de publier des journaux, des captures d\'écran ou des vidéos, supprimez les informations personnelles ou privées.</string>
    <string name="beta_sheet_nightly_title">Builds nightly</string>
    <string name="beta_sheet_nightly_summary">En quoi les nightlies diffèrent des releases, et quoi inclure quand elles plantent.</string>
    <string name="beta_sheet_nightly_body">Les builds nightly sont générées à partir du dernier commit et peuvent contenir des modifications inachevées, des bugs temporaires ou des régressions. Elles sont plus expérimentales que les releases officielles.</string>
    <string name="beta_sheet_nightly_access">Accédez-y depuis les artefacts de workflow GitHub Actions du dépôt si disponibles.</string>
    <string name="beta_sheet_nightly_report_title">Signaler des problèmes sur les nightlies</string>
    <string name="beta_sheet_nightly_report_body">Lorsque vous signalez un problème à partir d\'une build nightly, mentionnez toujours qu\'il s\'est produit sur une build nightly, et non sur la release officielle. Incluez la date de build, le nom ou le numéro d\'exécution du workflow, ou le commit SHA si possible. Vérifiez également si le même problème se produit sur la dernière release officielle.</string>
    <string name="beta05_title">Mise à niveau Bêta 0.5.0</string>
    <string name="beta05_clean_install_title">Installation propre recommandée</string>
    <string name="beta05_clean_install_body">Si vous venez de la bêta 0.5.0, cette mise à jour peut nécessiter de nouvelles données de bibliothèque plutôt que l\'ancien état en cache.</string>
    <string name="beta05_if_wrong_meta_title">Si les métadonnées ou les entrées de bibliothèque semblent incorrectes</string>
    <string name="beta05_if_wrong_meta_body">Mauvaises métadonnées de titre, artistes ou albums incorrects, ou entrées en double signifient généralement qu\'une installation propre est la solution.</string>
