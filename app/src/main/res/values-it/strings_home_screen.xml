    <!-- BetaInfoBottomSheet -->
    <string name="beta_sheet_version">Beta 0.7.0</string>
    <string name="beta_sheet_letter">β</string>
    <string name="beta_sheet_welcome_title">Benvenuto in PixelPlayer 0.7.0-beta</string>
    <string name="beta_sheet_welcome_body">Stai utilizzando una build beta che potrebbe contenere bug, crash o funzionalità sperimentali. Aiutaci a migliorare segnalando i problemi.</string>
    <string name="beta_sheet_expect_title">Cosa aspettarsi</string>
    <string name="beta_sheet_expect_1">Bug, crash o funzionalità incomplete possono verificarsi inaspettatamente.</string>
    <string name="beta_sheet_expect_2">Alcune funzionalità potrebbero cambiare o essere rimosse senza preavviso.</string>
    <string name="beta_sheet_expect_3">Le build beta potrebbero essere più instabili delle versioni ufficiali.</string>
    <string name="beta_sheet_expect_4">Controlla sempre gli aggiornamenti prima di segnalare un problema noto.</string>
    <string name="beta_sheet_expect_summary">Cosa possono cambiare, interrompere o migliorare le build beta durante i test.</string>
    <string name="beta_sheet_github_title">Scorciatoia issue GitHub</string>
    <string name="beta_sheet_github_body">Cerca prima, quindi apri una segnalazione mirata per bug, crash, richieste o domande.</string>
    <string name="beta_sheet_open_issues">Apri segnalazioni esistenti</string>
    <string name="beta_sheet_report_bug">Segnala un bug o crash</string>
    <string name="beta_sheet_report_body">Condividi i passaggi per riprodurre, il risultato atteso, il risultato effettivo e i dettagli del tuo dispositivo/SO.</string>
    <string name="beta_sheet_report_title">Come segnalare</string>
    <string name="beta_sheet_report_summary">Una rapida lista di controllo prima di aprire una nuova segnalazione.</string>
    <string name="beta_sheet_before_title">Prima di aprire una segnalazione</string>
    <string name="beta_sheet_before_1">Cerca tra le segnalazioni aperte e chiuse esistenti per evitare duplicati.</string>
    <string name="beta_sheet_before_2">Aggiorna all\'ultima versione di PixelPlayer e conferma che il problema si verifichi ancora.</string>
    <string name="beta_sheet_before_3">Riavvia l\'app e conferma che il problema persiste.</string>
    <string name="beta_sheet_before_4">Prova a riprodurlo e scrivi i passaggi esatti.</string>
    <string name="beta_sheet_issue_type_title">Quale tipo di segnalazione?</string>
    <string name="beta_sheet_issue_type_bug">Segnalazione bug: Qualcosa si comporta in modo errato.</string>
    <string name="beta_sheet_issue_type_feature">Richiesta funzionalità: Aggiungi una nuova funzionalità o miglioramento.</string>
    <string name="beta_sheet_issue_type_question">Domanda: Usa Discussioni se abilitate, o apri una segnalazione con l\'etichetta domanda.</string>
    <string name="beta_sheet_bug_title">Segnalazione bug</string>
    <string name="beta_sheet_bug_summary_text">Copia questi campi quando qualcosa si comporta in modo errato o va in crash.</string>
    <string name="beta_sheet_bug_template_title">Segnalazione Bug</string>
    <string name="beta_sheet_bug_summary">Breve riepilogo:</string>
    <string name="beta_sheet_bug_expected">Comportamento atteso:</string>
    <string name="beta_sheet_bug_actual">Comportamento attuale:</string>
    <string name="beta_sheet_bug_steps">Passaggi per riprodurre: 1. 2. 3.</string>
    <string name="beta_sheet_bug_frequency">Quanto spesso accade? Sempre / A volte / Raramente.</string>
    <string name="beta_sheet_bug_screenshot">Screenshot / video: se disponibile.</string>
    <string name="beta_sheet_bug_logs">Log / stack trace: se disponibile.</string>
    <string name="beta_sheet_env_title">Ambiente</string>
    <string name="beta_sheet_env_version">Versione PixelPlayer:</string>
    <string name="beta_sheet_env_source">Sorgente installazione: GitHub Release, build di debug, build nightly, ecc.</string>
    <string name="beta_sheet_env_android">Versione Android:</string>
    <string name="beta_sheet_env_device">Modello dispositivo:</string>
    <string name="beta_sheet_env_extra">Contesto aggiuntivo: uso della scheda SD, impostazioni speciali, permessi, ecc.</string>
    <string name="beta_sheet_feature_title">Richiesta funzionalità</string>
    <string name="beta_sheet_feature_summary">Copia questi campi quando desideri una nuova funzionalità o miglioramento.</string>
    <string name="beta_sheet_feature_problem">Descrizione del problema: Quale problema stai cercando di risolvere?</string>
    <string name="beta_sheet_feature_solution">Soluzione proposta: Come dovrebbe funzionare?</string>
    <string name="beta_sheet_feature_alternatives">Alternative considerate: Altri approcci?</string>
    <string name="beta_sheet_feature_scope">Ambito: Quali schermate o flussi sono interessati?</string>
    <string name="beta_sheet_feature_mockup">Mockup o immagine di riferimento se disponibile.</string>
    <string name="beta_sheet_quality_title">Titoli, privacy e ambito</string>
    <string name="beta_sheet_quality_summary">Rendi la segnalazione facile da valutare e sicura da condividere.</string>
    <string name="beta_sheet_title_examples_title">Buoni titoli di segnalazione</string>
    <string name="beta_sheet_title_example_1">Equalizzatore: L\'indicatore si sposta quando si cambia scheda dei preset</string>
    <string name="beta_sheet_title_example_2">Ricerca: La cronologia non appare per query vuote</string>
    <string name="beta_sheet_title_example_3">Funzionalità: Aggiungi l\'opzione di ordinamento playlist \"Aggiunti di recente\"</string>
    <string name="beta_sheet_avoid_title">Si prega di evitare</string>
    <string name="beta_sheet_avoid_1">Segnalazioni generiche come \"Non funziona\".</string>
    <string name="beta_sheet_avoid_2">Molteplici problemi non correlati in una singola segnalazione.</string>
    <string name="beta_sheet_avoid_3">Log o screenshot non oscurati con dati personali.</string>
    <string name="beta_sheet_privacy_title">Nota sulla privacy</string>
    <string name="beta_sheet_privacy_body">Prima di pubblicare log, screenshot o video, rimuovi le informazioni personali o private.</string>
    <string name="beta_sheet_nightly_title">Build nightly</string>
    <string name="beta_sheet_nightly_summary">Come le nightly differiscono dalle release, e cosa includere quando si interrompono.</string>
    <string name="beta_sheet_nightly_body">Le build nightly sono generate dall\'ultimo commit e potrebbero contenere modifiche incomplete, bug temporanei o regressioni. Sono più sperimentali delle release ufficiali.</string>
    <string name="beta_sheet_nightly_access">Accedi ad esse dagli artefatti del workflow di GitHub Actions del repository, se disponibili.</string>
    <string name="beta_sheet_nightly_report_title">Segnalazione problemi delle nightly</string>
    <string name="beta_sheet_nightly_report_body">Quando segnali un problema da una build nightly, menziona sempre che si è verificato su una nightly, non sulla release ufficiale. Includi la data della build, il nome o numero di esecuzione del workflow, o il commit SHA se possibile. Controlla anche se lo stesso problema si verifica sull\'ultima release ufficiale.</string>
    <string name="beta05_title">Aggiornamento beta 0.5.0</string>
    <string name="beta05_clean_install_title">Installazione pulita consigliata</string>
    <string name="beta05_clean_install_body">Se provieni dalla beta 0.5.0, questo aggiornamento potrebbe richiedere dati libreria freschi invece dello stato cache precedente.</string>
    <string name="beta05_if_wrong_meta_title">Se i metadati o le voci libreria sembrano errati</string>
    <string name="beta05_if_wrong_meta_body">Metadati brano errati, artisti o album non corrispondenti, o voci che sembrano duplicate di solito significano che un\'installazione pulita è la soluzione.</string>
