    <string name="multi_artist_ex_1_out">Artist1, Artist2</string>
    <string name="multi_artist_ex_2_in">\"Drake feat. Rihanna\"</string>
    <string name="multi_artist_ex_2_out">Drake, Rihanna</string>
    <string name="multi_artist_ex_3_in">\"Marshmello x Bastille\"</string>
